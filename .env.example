APP_ENV=development
APP_PORT=8082
APP_HOST=0.0.0.0

DATABASE_URL=postgres://profile:secret@localhost:5432/profile_db?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# Must match JWT_SECRET in auth-service and api-gateway
JWT_SECRET=your-secret-here

# Must match INTERNAL_SECRET in auth-service
INTERNAL_SECRET=your-internal-secret-here

RABBITMQ_URL=amqp://guest:guest@localhost:5672/

LOG_LEVEL=info
